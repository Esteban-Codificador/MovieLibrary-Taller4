<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/movieListFragment">

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.example.movielibrary.ui.MovieListFragment"
        android:label="MovieLibrary"
        tools:layout="@layout/fragment_movie_list">

        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@id/movieDetailFragment">
            <argument
                android:name="movieId"
                app:argType="integer" />
        </action>

        <action
            android:id="@+id/action_list_to_edit"
            app:destination="@id/movieEditFragment">
            <argument
                android:name="movieId"
                app:argType="integer"
                android:defaultValue="-1" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/movieDetailFragment"
        android:name="com.example.movielibrary.ui.MovieDetailFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_movie_detail">

        <argument
            android:name="movieId"
            app:argType="integer" />

        <action
            android:id="@+id/action_detail_to_edit"
            app:destination="@id/movieEditFragment">
            <argument
                android:name="movieId"
                app:argType="integer" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/movieEditFragment"
        android:name="com.example.movielibrary.ui.MovieEditFragment"
        android:label="Editar"
        tools:layout="@layout/fragment_movie_edit">

        <argument
            android:name="movieId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

</navigation>